{
  "config": {
    "default": true,
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD029": false,
    "MD033": false,
    "MD041": false,
    "MD060": false,
  },
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules",
    ".next",
    "out",
    "build",
    "playwright-report/**",
    "test-results/**",
    "requirements/**",
    "CLAUDE.md",
    "AGENTS.md",
  ],
}
